.idea/
*.swp

# local tool caches & agent state (regenerated locally)
.claude/settings.local.json
.claude/worktrees/
.fallow/

# secrets & credentials — NEVER commit (this is a public repo)
*.pem
*.key
*.p12
*.pfx
*.keystore
*.jks
*.crt
*.cer
.npmrc
secrets.json
credentials.json
auth.json

# local working notes (not for the public repo)
GITHUB-SETUP.md
SCAFFOLD-STATUS.md
local-notes/

# test coverage
coverage

# local design-system export for claude.ai/design — not needed to build the app
# (its source of truth is src/renderer/src/assets/main.css + docs/). If you'd rather
# version it as a design reference, drop this line and commit the folder instead.
vrx-design/

# Claude Code session-local tooling (mock-server launch configs etc.) — machine-specific, never shipped
/.claude/
